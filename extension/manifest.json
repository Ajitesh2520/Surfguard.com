{
  "manifest_version": 3,
  "name": "Focus AI",
  "version": "0.1.0",
  "description": "AI-powered browsing focus assistant",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "activeTab",
    "declarativeNetRequest"
  ],
  "background": {
    "service_worker": "src/background/index.ts"
  },
  "action": {
    "default_popup": "dist/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/blocker.ts"]
    }
  ]
}
