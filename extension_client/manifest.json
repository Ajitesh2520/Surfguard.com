{
  "manifest_version": 3,
  "name": "Focus AI",
  "version": "1.0",
  "permissions": ["storage", "tabs", "alarms", "declarativeNetRequest"],
  "host_permissions": ["http://localhost:3000/*"],
  "background": {
    "service_worker": "background/index.js"
  },
  "action": {
    "default_popup": "dist/index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/blocker.js"]
    }
  ]
}